# .env.example — Copia este archivo como .env y ajusta los valores

# Aplicación
APP_PORT=3000
APP_ENV=development

# Base de datos
DB_TYPE=sqlite
DB_DATABASE=database.sqlite
# DB_HOST=localhost      # Para PostgreSQL o MySQL
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_DATABASE=mi_base

# Seguridad
JWT_SECRET=cambia_este_secreto_en_produccion
JWT_EXPIRES=3600s
